<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Welcome</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background: #f4f4f4;
            text-align: center;
            padding-top: 80px;
        }
        .welcome-box {
            background: white;
            padding: 30px;
            margin: auto;
            width: 350px;
            border-radius: 10px;
            box-shadow: 0 0 10px rgba(0,0,0,0.1);
        }
        button {
            margin-top: 15px;
            padding: 10px 20px;
            border: none;
            background: #0078ff;
            color: white;
            border-radius: 5px;
            cursor: pointer;
        }
        button:hover {
            background: #005fcc;
        }
    </style>
</head>
<body>

    <div class="welcome-box">
        <h1>Welcome to Our Website</h1>
        <p>We're happy to have you here.</p>
        <button onclick="sayHello()">Click to Say Hello</button>
        <p id="message"></p>
    </div>

    <script>
        function sayHello() {
            document.getElementById("message").innerText = "Enjoy your visit!";
        }
    </script>

</body>
</html>
